  "main": "index.js",
  "scripts": {
    "start": "expo start 2>&1 | tee /tmp/expo.log",
    "dev": "expo start --dev-client 2>&1 | tee /tmp/expo.log",
    "android": "expo run:android",
    "prebuild": "expo prebuild --platform android --clean",
    "build:dev": "eas build --platform android --profile development",
    "build:preview": "eas build --platform android --profile preview",
    "build:prod": "eas build --platform android --profile production",
    "build:local": "eas build --platform android --profile development --local",
    "typecheck": "tsc --noEmit"
  },
