    "@libp2p/tcp": "^11.0.0",
    "@libp2p/websockets": "^10.0.0",
    "@libp2p/yamux": "^8.0.0",
    "@multiformats/multiaddr": "^13.0.1",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@peculiar/webcrypto": "^1.5.0",
